generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  roleId String
  iconId Int? 
  firstName String @db.VarChar(35)
  lastName String @db.VarChar(35) 
  email String @db.VarChar(320) @unique
  username String @db.VarChar(16) @unique
  password String @db.VarChar(255)
  isActive Boolean @default(false)
  activationToke String? @db.VarChar(32)
  gdpr Boolean @default(true)
  createdAt DateTime @db.Timestamp() @default(now())
  updatedAt DateTime @db.Timestamp() @default(now())
  icon Icon? @relation(fields: [iconId], references: [id])
  role Role @relation(fields: [roleId], references: [id])
  message Message[]
  post Post[]
}

model Icon {
  id Int @id @default(autoincrement())
  image String @db.VarChar(255)
  user User[]
}
model Role {
  id String @id @default(uuid())
  name String @db.VarChar(32) @unique
  user User[]
}
model User_Has_Project{
  id String @id @default(uuid())
  userId String 
  projectId String
  roleProjectId String
  isBanned Boolean @default(false)
  createdAt DateTime @db.Timestamp() @default(now())
  role Role_Project @relation(fields: [roleProjectId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}

model Project {
  id String @id @default(uuid())
  name String @db.VarChar(16)
  createdAt DateTime @db.Timestamp() @default(now())
  updatedAt DateTime @db.Timestamp() @default(now())
  link Link_Project[]
  section Section[]
  message Message[]
  users User_Has_Project[]
}
model Section {
  id String @id @default(uuid())
  name String @db.VarChar(16)
  projectId String
  post Post[]
  project Project @relation(fields: [projectId], references: [id])
}

model Post {
  id String @id @default(uuid())
  userId String  
  sectionId String 
  text String @db.VarChar(255) 
  poseX Int?
  poseY Int?
  isVisible Boolean @default(true)
  createdAt DateTime @db.Timestamp() @default(now())
  updatedAt DateTime @db.Timestamp() @default(now())
  user User @relation(fields: [userId] , references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  }

model Message{
  id String @id @default(uuid())
  projectId String 
  authorId String 
  message String @db.VarChar(255) 
  isVisible Boolean @default(true)
  createdAt DateTime @db.Timestamp() @default(now())
  updatedAt DateTime @db.Timestamp() @default(now())
  user User @relation(fields: [authorId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}

model Link_Project { 
  id String @id @default(uuid())
  projectId String  
  numberUsage Int @db.SmallInt() @default(10)
  createdAt DateTime @db.Timestamp() @default(now())
  outdatedAt DateTime
  projet Project @relation(fields: [projectId], references: [id])
}

model Role_Project{
  id String @id @default(uuid())
  name String @db.VarChar(50)  @unique
  users User_Has_Project[]
}