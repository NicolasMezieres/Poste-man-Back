{
  "coveragePathIgnorePatterns": ["src/prisma/generated"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFilesAfterEnv": ["./test/setup.e2e.ts"],
  "rootDir": "../../src",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/$1"
  }
}
